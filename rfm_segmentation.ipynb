import pandas as pd
import numpy as np
import datetime as dt

# ==========================================
# 1. Load Data
# ==========================================
customers = pd.read_csv('customers.csv')
orders = pd.read_csv('orders.csv')
support_tickets = pd.read_csv('support_tickets.csv')

# Define the snapshot date as given in the Data Dictionary
SNAPSHOT_DATE = pd.to_datetime('2025-09-30')

# Filter orders to prevent data leakage
orders['order_date'] = pd.to_datetime(orders['order_date'])
orders_pre_snapshot = orders[orders['order_date'] <= SNAPSHOT_DATE].copy()

# ==========================================
# 2. Calculate RFM Metrics
# ==========================================
# Calculate Recency (days since last order), Frequency (count of orders), Monetary (sum of spend)
rfm = orders_pre_snapshot.groupby('customer_id').agg({
    'order_date': lambda x: (SNAPSHOT_DATE - x.max()).days, # Recency
    'order_id': 'nunique',                                  # Frequency
    'gross_amount': 'sum'                                   # Monetary
}).reset_index()

rfm.rename(columns={
    'order_date': 'Recency',
    'order_id': 'Frequency',
    'gross_amount': 'Monetary'
}, inplace=True)

# ==========================================
# 3. Add Non-RFM Signals
# ==========================================
# Signal 1: Support Ticket Count
ticket_counts = support_tickets.groupby('customer_id')['ticket_id'].nunique().reset_index()
ticket_counts.rename(columns={'ticket_id': 'support_ticket_count'}, inplace=True)

# Merge back to RFM table
rfm = rfm.merge(ticket_counts, on='customer_id', how='left')
rfm['support_ticket_count'].fillna(0, inplace=True) # Fill nan with 0 for customers with no tickets

# ==========================================
# 4. Create Segmentation Logic (Example)
# ==========================================
# Note: You will need to adjust these thresholds based on your EDA from Part 1!
def assign_segment(row):
    if row['Recency'] < 30 and row['Frequency'] >= 5 and row['Monetary'] > 2000:
        return 'Champions'
    elif row['Recency'] > 90 and row['Frequency'] > 1 and row['support_ticket_count'] > 2:
        return 'High-Value Unhappy (At Risk)'
    elif row['Recency'] > 120 and row['Frequency'] == 1:
        return 'Dormant'
    # Add your own logic for Discount-sensitive, New Customers, etc.
    else:
        return 'Regular Customers'

rfm['Segment'] = rfm.apply(assign_segment, axis=1)

# Save the output file required by the capstone instructions
rfm[['customer_id', 'Segment', 'Recency', 'Frequency', 'Monetary', 'support_ticket_count']].to_csv('segments.csv', index=False)
print("RFM logic complete. Segments saved to segments.csv")
